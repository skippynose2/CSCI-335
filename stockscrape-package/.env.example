# ROIC.ai API key (https://www.roic.ai/ — free trial with AAPL, Premium for all tickers)
ROIC_API_KEY=your_roic_api_key_here

# Database URL
# PostgreSQL: postgresql://user:password@localhost:5432/stockscrape
# SQLite (quick local dev): sqlite:///stockscrape.db
DATABASE_URL=sqlite:///stockscrape.db

# Direction threshold (percentage). UP if return > threshold, DOWN if < -threshold, else FLAT.
DIRECTION_THRESHOLD=0.5
